    }
    if (j>i) {
      X = as.matrix(sapply(j:(j-i+1),function(k) Growth[k:(n.sample+k-1)]))
      Z = sapply(j:1,function(k) Growth[k:(n.sample+k-1)])
    }else{
      X = as.matrix(sapply(i:1,function(k) Growth[k:(n.sample+k-1)]))
      Z = sapply(j:1,function(k) Growth[k:(n.sample+k-1)])
    }
    result[[i]] = c(result[[i]],list(MCP(X,Y,Z,K_max,-2,-1,-1,2,1,1)))
  }
}
AIC = matrix(nrow = p_max,ncol = (q_max-1))
for (i in 1:p_max) {
  for (j in 2:q_max) {
    n.sample = n - max(c(i,j))
    Y = Growth[max(c(i,j)+1):n]
    if (i>j) {
      X = as.matrix(sapply(i:1,function(k) Growth[k:(n.sample+k-1)]))
      Z = sapply(i:(i-j+1),function(k) Growth[k:(n.sample+k-1)])
    }
    if (j>i) {
      X = as.matrix(sapply(j:(j-i+1),function(k) Growth[k:(n.sample+k-1)]))
      Z = sapply(j:1,function(k) Growth[k:(n.sample+k-1)])
    }else{
      X = as.matrix(sapply(i:1,function(k) Growth[k:(n.sample+k-1)]))
      Z = sapply(j:1,function(k) Growth[k:(n.sample+k-1)])
    }
    if (is.null(result[[i]][[j-1]]$beta)) {
      AIC[i,j-1] = n.sample*log(mean((Y - X%*%(result[[i]][[j-1]]$alpha[1,]))^2)) + 2*i
    }else{
      theta = result[[i]][[j-1]]$theta; beta = result[[i]][[j-1]]$beta; alpha = result[[i]][[j-1]]$alpha
      threshold_start = c(min(Z%*%beta)-1,theta); threshold_end = c(theta,max(Z%*%beta)+1)
      MSE = sum(sapply(1:length(threshold_start),function(k) sum((Y[(Z%*%beta>=threshold_start[k])&(Z%*%beta<threshold_end[k])]-(X%*%alpha[k,])[(Z%*%beta>=threshold_start[k])&(Z%*%beta<threshold_end[k]),])^2)))/n.sample
      AIC[i,j-1] = n.sample*log(MSE) + 2*i*length(threshold_start) + 2*(j-1)+ 2*(length(threshold_start)-1)
    }
  }
}

