##Smoothing method(Initial estimator)
Smooth= function(X,Y,Z,K_max,L.alpha,L.beta,L.theta,U.alpha,U.beta,U.theta,n.optim=20){
  #the first (threshold_num+1)*p elements of L and U are the lower and upper bound of alpha respectively
  #the last threshold_num elements of L and U are the lower and upper bound of theta respectively
  require(GA)
  p = ncol(X); q = ncol(Z); n = nrow(X); h = log(n)/n
  IC = function(threshold_num){
    return(log(-result$fitness)+1/sqrt(n)*(threshold_num+1))
  }
  fitness = function(coefficient){
    alpha = coefficient[1:(threshold_num*p+p)]; beta = coefficient[(threshold_num*p+p+1):(threshold_num*p+p+q-1)]; theta = coefficient[(threshold_num*p+p+q):length(coefficient)]
    residual = Y - X%*%alpha[1:p]
    for (i in 1:threshold_num) {
      residual = residual - X%*%alpha[(i*p+1):((i+1)*p)]*pnorm(((Z[,1]+as.matrix(Z[,2:q])%*%beta)-theta[i])/h)
    }
    return(-mean(residual^2))
  }
  smooth_result = list()
  for (i in 1:(K_max-1)) {
    threshold_num = i
    lower = c(rep(L.alpha,(i+1)*p),rep(L.beta,q-1),rep(L.theta,i)); upper = c(rep(U.alpha,(i+1)*p),rep(U.beta,q-1),rep(U.theta,i)); result = list()
    result = lapply(1:n.optim,function(i){
      summary(ga(type = "real-valued", fitness = fitness, lower = lower,upper = upper, monitor = NULL))
    })
    result = result[[which.max(sapply(1:n.optim, function(i) result[[i]]$fitness))]]
    estimated_theta = result$solution[(threshold_num*p+p+q):length(result$solution)]
    estimated_alpha = matrix(result$solution[1:(threshold_num*p+p)],ncol = p,byrow = T)
    estimated_beta = c(1,result$solution[(threshold_num*p+p+1):(threshold_num*p+p+q-1)])
    estimated_alpha = estimated_alpha[c(1,order(estimated_theta)+1),]
    estimated_alpha = matrix(estimated_alpha,ncol=p);rownames(estimated_alpha) = paste("group",1:(threshold_num+1))
    estimated_theta = sort(estimated_theta)
    value = IC(threshold_num)
    smooth_result[[i]] = list(alpha=estimated_alpha,beta=estimated_beta,theta=estimated_theta,value=value)
  }
  smooth_result = smooth_result[[which.min(sapply(1:(K_max-1),function(i) smooth_result[[i]]$value))]]
  return(smooth_result)
}
##Group fused lasso
GFL = function(X,Y,Z,beta,lambda){
  require(sparseGFL); require(GGFL)
  p = ncol(X); q = ncol(Z); n = nrow(X)
  #automatically select lambda
  if (is.null(lambda)) {
    lambda_max = max(sqrt((rowSums(apply(as.matrix((X*replicate(p,residuals(lm(Y~X-1))))[n:1,]),2,cumsum)^2))))
    lambda = lambda_max*0.98^c(99:0)
  }
  #information criterion to select lambda
  IC = function(results){
    MSE = mean((ordered_Y - ordered_X*(t(results$beta)))^2)
    return(log(MSE)+(length(results$changePoints)+1)/sqrt(n))
  }
  #area, group factor
  group = function(location){
    location = c(1,location,n+1)
    area = rep(1,location[1]-1)
    for (i in 2:length(location)) {
      area = c(area,rep(i-1,(location[i]-location[i-1])))
    }
    return(area)
  }
  #adjacency matrix for adaptive group fused lasso
  adj_mat = function(location){
    threshold_num = length(location)
    adj = matrix(nrow = threshold_num*2,ncol = 2)
    for (i in 1:(threshold_num+1)) {
      if (i==1) {
        adj[i,1] = i; adj[i,2] = i+1
      }else{
        if (i==(threshold_num+1)) {
          adj[2*threshold_num,1] = i; adj[2*threshold_num,2] = i-1
        }else{
          adj[(2*i-2):(2*i-1),1] = i; adj[2*i-2,2] = i-1; adj[2*i-1,2] = i+1
        }
      }
    }
    adj = data.frame(adj); colnames(adj) = c("area","adj")
    return(adj)
  }
  #Group fused lasso
  order_W = order(Z%*%beta); ordered_W = (Z%*%beta)[order_W]
  ordered_Y = Y[order_W]; ordered_X = as.matrix(X[order_W,])
  ordered_Y = matrix(ordered_Y,nrow = 1, ncol = n); ordered_X = array(t(ordered_X),c(1,p,n))
  results = lapply(1:length(lambda), function(i) SGFL(ordered_X,ordered_Y,0,lambda[i],intercept = F))
  ordered_Y = Y[order_W]; ordered_X = as.matrix(X[order_W,])
  index = which.min(sapply(1:length(lambda), function(i) IC(results[[i]])))
  location = results[[index]]$changePoints
  while (length(location)==0) {
    index = which.min(sapply(1:(index-1), function(i) IC(results[[i]])))
    location = results[[index]]$changePoints
  }
  #adaptive group fused lasso
  area = group(location); adj = adj_mat(location)
  results = GGFL(ordered_Y,ordered_X,area,adj,adaptive = T, standardize = F,Lambda = 1,lambda.type = "value",MPinv = T,intercept = F)
  w = lapply(results$weight,function(x) x^2)
  results = GGFL::GGFL(ordered_Y,ordered_X,area,adj,adaptive = F,weight = w, standardize = F,lambda.type = "value",MPinv = T,out.all = T,intercept =F)
  index = which.min(log(results$log$rss) + apply(results$all.cluster,1,max)/sqrt(n)); Lambda = results$log$lambda[index]
  estimated_alpha = results$all.coef[[index]]; index = c(); results = list(); results$alpha = estimated_alpha
  if ((length(unique(estimated_alpha[,1]))-1)==0) {
    results$changePoints = NULL
  }else{
    for (i in 1:(length(unique(estimated_alpha[,1]))-1)) {
      index[i] = max(which(estimated_alpha[,1]==(unique(estimated_alpha[,1])[i])))
    }
    results$changePoints = location[index]
    results$alpha = unique.matrix(results$alpha)
  }
  return(list(results=results,order_W=order_W,ordered_W=ordered_W))
}
##Linear program
LP = function(X,Y,Z,results,order_W,ordered_W,L.beta,U.beta,epsilon = 1e-06,n.samples = 4){
  require(highs); q = ncol(Z); n = nrow(Z)
  cp = results$changePoints; cp_start = c(1,cp); cp_end = c(cp-1,n)
  theta = ordered_W[cp]; all_theta = c(-100,theta,100)
  K = nrow(results$alpha); sq_res = c(sapply(1:K, function(i) (Y-X%*%results$alpha[i,])^2))
  A = c(); for(i in 1:K){ A = cbind(A,diag(n))}; A = cbind(A,matrix(0,ncol = (q-1),nrow = n))
  A_star = vector("list", 2)
  for(i in 1:2){
    for (j in 1:K) {
      A_star[[i]] = cbind(A_star[[i]],-diag(n)*all_theta[i+j-1])
    }
    A_star[[i]] = cbind(A_star[[i]],Z[,-1])
    A = rbind(A,A_star[[i]])
  }
  #objective perturbation to calculate centroid
  estimated_beta = matrix(nrow = n.samples,ncol = q-1)
  for (i in 1:n.samples) {
    estimated_beta[i,] = highs_solve(
      L = c(sq_res,replicate(q-1,epsilon*rnorm(1))),
      A = A,
      lhs = c(rep(1,n),-Z[,1],rep(-Inf,n)),
      rhs = c(rep(1,n),rep(Inf,n),-Z[,1]-epsilon),
      types = c(rep("I",length(sq_res)),rep("C",(q-1))),
      lower = c(rep(0,length(sq_res)),rep(L.beta,q-1)),
      upper = c(rep(1,length(sq_res)),rep(U.beta,q-1))
    )$primal_solution[(K*n+1):(K*n+q-1)]
  }
  estimated_beta = c(1,colMeans(estimated_beta))
  return(estimated_beta)
}
##Estimation
MCP = function(X,Y,Z,K_max,L.alpha,L.beta,L.theta,U.alpha,U.beta,U.theta,lambda=NULL,iter=5,tol=1e-6){
  n = nrow(X); q = ncol(Z)
  #Initial value
  MAE = 1; iter_num = 0
  #Initial estimation
  Initial = Smooth(X,Y,Z,K_max,L.alpha,L.beta,L.theta,U.alpha,U.beta,U.theta); estimated_beta = Initial$beta
  #Group fused lasso
  GFL_results = GFL(X,Y,Z,estimated_beta,lambda); results = GFL_results$results; order_W = GFL_results$order_W; ordered_W = GFL_results$ordered_W
  if(length(results$changePoints)!=0){
    while ((iter_num<iter)&(MAE>tol)) {
      iter_num = iter_num + 1
      MAE = ifelse(iter_num<=1,1,abs(LP(X,Y,Z,results,order_W,ordered_W,L.beta,U.beta)[-1]-estimated_beta[-1]))
      #Linear program
      estimated_beta = LP(X,Y,Z,results,order_W,ordered_W,L.beta,U.beta)
      #Group fused lasso
      GFL_results = GFL(X,Y,Z,estimated_beta,lambda); results = GFL_results$results; order_W = GFL_results$order_W; ordered_W = GFL_results$ordered_W
      estimated_alpha = unique(results$alpha)
      if (length(results$changePoints)==0) {
        break
      }
    }
  }
  if (length(results$changePoints)==0) {
    estimated_alpha = results$alpha
    return(list(alpha=estimated_alpha,smooth=Initial))
  }else{
    return(list(alpha=estimated_alpha,beta=estimated_beta,theta=ordered_W[results$changePoints],smooth=Initial))
  }
}

