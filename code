require(readxl); setwd("/icto/user/yc47006/R/MTCPAR")
Data = read_excel("GNP55.xlsx"); Growth = diff(log(Data$GNP))*100
p_max = 6; q_max = 6; K_max = 4; n = length(Growth)
result = vector("list",p_max); set.seed(12345678)
for (i in 1:p_max) {
  for (j in 2:q_max) {
    n.sample = n - max(c(i,j))
